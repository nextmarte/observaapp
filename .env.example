# ObservaApp — Environment Variables Example
#
# Copy this file to .env.local and fill in your Supabase credentials
# to connect a real backend instead of the local mock data.
#
# See PRD.md > "Como Conectar a um Backend Real" for full instructions.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
